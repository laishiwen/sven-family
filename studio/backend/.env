# ── Studio Backend Configuration ──────────────────────────────────────────────
# 自身服务
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
APP_LOG_LEVEL=info

# ── 数据存储 ───────────────────────────────────────────────────────────────────
# SQLite (默认，开发环境零配置)
# SQLITE_PATH=/path/to/sven_studio.db
# Milvus Lite（向量存储）
# MILVUS_LITE_PATH=/path/to/milvus_lite.db

# ── 数据目录（macOS 默认 ~/Data/SvenStudio/AppData）───────────────────────────
# APP_DATA_DIR=/path/to/data
# APP_LOG_DIR=/path/to/logs

# ── 外部服务 ───────────────────────────────────────────────────────────────────
# Langfuse 可观测性（可选）
LANGFUSE_HOST=https://cloud.langfuse.com
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=

# 搜索服务 API Keys（可选）
# SEARCH_TAVILY_API_KEY=
# SEARCH_BRAVE_API_KEY=
# SEARCH_SERPAPI_KEY=

# ── MCP / Skills 运行时 ────────────────────────────────────────────────────────
MANAGED_NODE_VERSION=v20.12.2
MANAGED_NPM_REGISTRY=https://registry.npmjs.org
MANAGED_RUNTIME_TIMEOUT_SEC=300
SKILLS_CLI_PACKAGE=skills
MCP_CLI_PACKAGE=@getmcp/cli

# ── 文件上传限制 ───────────────────────────────────────────────────────────────
FILE_UPLOAD_MAX_MB=100
