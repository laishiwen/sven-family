@layer components {
  /* Unified shadcn compat utility classes */
  .card {
    @apply rounded-xl border bg-card text-card-foreground shadow-sm;
  }
  .input {
    @apply flex w-full rounded-md border border-input bg-transparent px-3 py-2 text-sm shadow-sm transition-colors file:border-0 file:bg-transparent file:text-sm file:font-medium placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring disabled:cursor-not-allowed disabled:opacity-50;
  }
  .label {
    @apply text-sm font-medium leading-none peer-disabled:cursor-not-allowed peer-disabled:opacity-70 mb-1 block;
  }
  .badge {
    @apply inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-semibold transition-colors focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2;
  }
  .badge-gray {
    @apply border-transparent bg-secondary text-secondary-foreground hover:bg-secondary/80;
  }
  .badge-success {
    @apply border-transparent bg-green-500 text-primary-foreground hover:bg-green-500/80;
  }
  .badge-warning {
    @apply border-yellow-200 bg-transparent text-yellow-600;
  }
  .badge-error {
    @apply border-transparent bg-destructive text-destructive-foreground hover:bg-destructive/80;
  }
  .btn-primary {
    @apply inline-flex items-center justify-center whitespace-nowrap rounded-md text-sm font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 bg-primary text-primary-foreground hover:bg-primary/90 h-10 px-4 py-2;
  }
  .btn-secondary {
    @apply inline-flex items-center justify-center whitespace-nowrap rounded-md text-sm font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 bg-secondary text-secondary-foreground hover:bg-secondary/80 h-10 px-4 py-2;
  }
  .btn-danger {
    @apply inline-flex items-center justify-center whitespace-nowrap rounded-md text-sm font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 bg-destructive text-destructive-foreground hover:bg-destructive/90 h-10 px-4 py-2;
  }

  .section-header {
    @apply flex items-center justify-between mb-6;
  }

  .page-title {
    @apply text-2xl font-bold text-slate-900 dark:text-slate-100;
  }

  .code-block {
    @apply font-mono text-sm bg-slate-900 dark:bg-slate-950 text-slate-100 rounded-lg p-4 overflow-auto;
  }
