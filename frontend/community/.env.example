# ── Community Frontend Configuration ───────────────────────────────────────────
# 本地开发：连接本地后端
# NEXT_PUBLIC_BRIDGE_API_URL=http://localhost:50051

# 生产环境：连接公网 API 域名（Docker 构建时通过 --build-arg 传入）
NEXT_PUBLIC_BRIDGE_API_URL=http://localhost:50051

# 统计服务（社区埋点上报，静默）
# 本地开发：http://localhost:8002
NEXT_PUBLIC_STATS_API_URL=http://localhost:8002