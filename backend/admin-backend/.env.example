# ── Admin Backend Configuration ────────────────────────────────────────────────
# 自身服务数据库
DATABASE_URL=postgresql+asyncpg://postgres:123456@localhost:5432/butler

# Redis（缓存 / 会话）
REDIS_URL=redis://localhost:6379/0

# JWT 认证
JWT_SECRET_KEY=dev-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# CORS 允许的前端来源
# 统一变量命名（与 backend/.env / compose / workflow 对齐）
ADMIN_CORS_ORIGINS=["http://localhost:5174","http://localhost:5173","http://localhost:3002"]

# ── 连接目标：下游服务（内网通信）──────────────────────────────────────────────
# Community Backend (admin mode — 内网)
COMMUNITY_BRIDGE_URL=http://127.0.0.1:50051
# Crawler Service（爬虫触发 — 内网）
CRAWLER_SERVICE_URL=http://127.0.0.1:9100
# Stats Service（统计查询 — 内网）
STATS_SERVICE_URL=http://127.0.0.1:8002
