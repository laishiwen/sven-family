# ── Crawler Configuration ────────────────────────────────────────────────────

# 连接目标：Community Backend (admin mode — 内网)
COMMUNITY_BRIDGE_URL=http://127.0.0.1:50051

# Redis (for URL deduplication)
REDIS_URL=redis://localhost:6379/0

# Log level: DEBUG, INFO, WARNING, ERROR
CRAWLER_LOG_LEVEL=INFO

# ── Spider Schedules (cron: minute hour day month weekday) ────────────────────
SPIDER_HACKERNEWS_SCHEDULE=0 */6 * * *
SPIDER_DEVTO_SCHEDULE=15 */8 * * *
SPIDER_GITHUB_TRENDING_SCHEDULE=30 */12 * * *

# ── Content ───────────────────────────────────────────────────────────────────
# Max articles per spider run
SPIDER_MAX_ARTICLES_PER_RUN=3
# Max content length before truncation (copyright compliance)
SPIDER_MAX_CONTENT_LENGTH=1200

# ── Ingestion ─────────────────────────────────────────────────────────────────
# Auto-publish crawled posts (true=published, false=pending_review)
CRAWLER_AUTO_PUBLISH=true
# HTTP request timeout (seconds)
CRAWLER_REQUEST_TIMEOUT=15

# ── Dedup ─────────────────────────────────────────────────────────────────────
# URL deduplication TTL (days)
DEDUP_TTL_DAYS=7
